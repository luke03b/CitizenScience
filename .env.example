# Database Configuration
POSTGRES_DB=citizenscience
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password_here

# JWT Configuration
JWT_SECRET=change-me-generate-a-secure-256-bit-secret-key
JWT_EXPIRATION=86400000

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080,http://localhost:8081

# AI Containers Configuration
# Comma-separated list of Docker service names that expose /models and /identify endpoints.
# Add more container names here to enable multi-container AI support.
# Example with placeholder service for testing: AI_CONTAINERS=ai_service,ai_service_placeholder
AI_CONTAINERS=ai_service,ai_service_placeholder
